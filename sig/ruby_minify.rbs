module RubyMinify
  VERSION: String

  class Error < StandardError
  end

  class MinifyError < Error
  end

  class SyntaxError < Error
  end

  type tp_node = TypeProf::Core::AST::Node
  type tp_genv = TypeProf::Core::GlobalEnv

  def self.location_key: (Prism::Node | tp_node node) -> [Integer, Integer]
  def location_key: (Prism::Node | tp_node node) -> [Integer, Integer]

  DYNAMIC_VARIABLE_METHODS: Array[Symbol]

  module UnionFind
    def uf_init: () -> void
    def uf_root: (method_key key) -> method_key
    def merge_groups: (method_key key1, method_key key2) -> void

    private

    def uf_add: (method_key key) -> void
    def uf_remove: (method_key key) -> void
  end

  # --- scope_management.rb ---
  def build_scope_mappings: (tp_node nodes, Hash[Integer, Hash[Symbol, String]] scope_mappings, ?kw_def_map: Hash[Integer, Hash[Symbol, String]]?, ?var_hints_map: Hash[Integer, Hash[Symbol, String]]?) -> void
  def register_top_level_scope: (tp_node nodes, Hash[Integer, Hash[Symbol, String]] scope_mappings) -> void
  def collect_scope_vars: (tp_node node, Hash[Integer, Hash[Symbol, String]] scope_mappings, ?kw_def_map: Hash[Integer, Hash[Symbol, String]]?, ?var_hints_map: Hash[Integer, Hash[Symbol, String]]?) -> void
  def collect_extra_block_param_names: (Prism::ParametersNode? prism_params) -> Array[Symbol]
  def get_body_cref_id: (tp_node? body) -> Integer?
  def collect_parent_mangled_names: (tp_node? body, Hash[Integer, Hash[Symbol, String]] scope_mappings) -> Array[String]
  def should_use_numbered_params?: (tp_node node, Array[String] parent_mangled_names) -> bool
  def collect_unused_rescue_vars: (tp_node? body) -> Set[Symbol]
  def check_dynamic_pattern: (tp_node node) -> bool
  def collect_multi_target_names: (Prism::MultiTargetNode multi_target_node) -> Array[Symbol]
  def get_mangled_name: (tp_node node, Symbol var, Hash[Integer, Hash[Symbol, String]] scope_mappings) -> String

  # --- analysis/method/collection.rb ---
  def collect_method_definitions: (tp_node nodes, tp_genv genv) -> void
  def resolve_method_calls: (tp_genv genv, tp_node nodes) -> void
  def scan_dynamic_method_references: (tp_node nodes) -> void
  def collect_visibility_modifier_methods: (tp_node nodes) -> void
  def collect_alias_undef_methods: (tp_node nodes) -> void

  DYNAMIC_DISPATCH_METHODS: Array[Symbol]
  VISIBILITY_MODIFIERS: Array[Symbol]

  private

  def link_module_function_variant: (tp_genv genv, Array[Symbol] cpath, bool singleton, Symbol mid, method_key method_key) -> void
  def resolve_def_receiver_cpath: (tp_node? receiver, tp_genv genv) -> Array[Symbol]?
  def build_cpath_from_prism_node: (Prism::Node node) -> Array[Symbol]?
  def merge_super_groups: (Array[[method_key, method_key]] super_merges) -> void
  def merge_polymorphic_groups: (Hash[Integer, Array[method_key]] call_node_to_keys) -> void
  def merge_unresolved_calls: (tp_node nodes, Set[Integer] resolved_call_ids, tp_genv genv) -> void
  def classify_unresolved_call: (Symbol mid, tp_node node, tp_genv genv) -> Symbol

  public

  # --- analysis/constant/collection.rb ---
  def syntax_data: (tp_node subnode) -> Hash[Symbol, untyped]
  def normalize_const_write_cpath: (tp_node node) -> Array[Symbol]
  def resolve_constant_read_cpath: (tp_node node) -> Array[Symbol]?
  def build_constant_path: (tp_node node) -> Array[Symbol]?
  def resolve_constant_path: (tp_node const_node, tp_node current_scope) -> Array[Symbol]?
  def exclude_private_constants: (tp_node nodes) -> void
  def collect_constants: (tp_node nodes) -> void
  def count_constant_references: (tp_node nodes) -> void
  def increment_constant_read_usage: (tp_node node) -> void
  def resolve_user_defined_cpath: (tp_node node) -> Array[Symbol]?
  def augment_constant_counts_via_typeprof: (tp_genv genv) -> void
  def collect_external_references: (tp_node nodes) -> void

  # --- analysis/ivar/collection.rb ---
  DYNAMIC_IVAR_METHODS: Array[Symbol]

  def collect_ivar_definitions: (tp_node nodes, Hash[Array[Symbol], Set[Symbol]] attr_backed) -> void
  def collect_attr_backed_ivars: (tp_node nodes) -> Hash[Array[Symbol], Set[Symbol]]
  def scan_dynamic_ivar_access: (tp_node nodes) -> void
  def merge_inherited_ivars: (tp_genv genv) -> void
  def reserve_attr_ivar_names: (tp_node nodes) -> void
  def coordinate_attr_renames: (tp_node nodes, tp_genv genv, Hash[[Integer, Integer], String] rename_map, Hash[[Integer, Integer], String] attr_ivar_entries) -> Hash[[Integer, Integer], Hash[Symbol, String]]

  # --- analysis/keyword/collection.rb ---
  def collect_keyword_info: (tp_node nodes, tp_genv genv) -> void

  private

  def collect_keyword_call_sites: (tp_genv genv, tp_node nodes) -> void
  def exclude_unresolved_keyword_calls: (tp_node nodes, tp_genv genv) -> void

  public

  # --- analysis/cvar/collection.rb ---
  DYNAMIC_CVAR_METHODS: Array[Symbol]

  def collect_cvar_definitions: (tp_node nodes) -> void
  def scan_dynamic_cvar_access: (tp_node nodes) -> void
  def merge_inherited_cvars: (tp_genv genv) -> void

  # --- analysis/gvar/collection.rb ---
  def collect_gvar_definitions: (tp_node nodes) -> void
  def scan_alias_globals: (tp_node nodes) -> void

  # --- analysis/method_aliases.rb ---
  METHOD_ALIASES: Hash[Symbol, Symbol]
  METHOD_TRANSFORMS: Hash[[Symbol, Symbol], String]

  # --- analysis/method_aliasing.rb ---
  def resolve_method_aliases_and_transforms: (tp_node nodes, tp_genv genv) -> [Hash[[Integer, Integer], Symbol], Hash[[Integer, Integer], String]]

  private

  def alias_available_on_receiver?: (tp_node? recv_node, Symbol shorter_method, tp_genv genv) -> bool
  def method_available_on_type?: (tp_genv genv, TypeProf::Core::ModuleEntity mod, bool singleton, Symbol method_name) -> bool
  def receiver_matches_type?: (tp_node? recv_node, Symbol type_name, tp_genv genv) -> bool
  def mod_is_or_inherits?: (tp_genv genv, TypeProf::Core::ModuleEntity mod, TypeProf::Core::ModuleEntity target) -> bool
end
