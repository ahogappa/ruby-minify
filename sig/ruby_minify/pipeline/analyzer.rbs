module RubyMinify
  module Pipeline
    class Analyzer < Stage
      include RubyMinify

      def call: (ConcatenatedSource source) -> AnalysisResult
      def syntax_data_for: (Prism::ProgramNode prism_ast) -> Hash[Array[Integer], Hash[Symbol, untyped]]
      def self.prism_only: (ConcatenatedSource source) -> AnalysisResult
      def self.prism_only_from_string: (String content, ?source: ConcatenatedSource?) -> AnalysisResult

      private

      def setup_typeprof: (ConcatenatedSource source) -> [Prism::ParseResult, TypeProf::Core::AST::Node, TypeProf::Core::GlobalEnv]
      def analyze_keywords_and_scopes: (TypeProf::Core::AST::Node nodes, TypeProf::Core::GlobalEnv genv) -> void
      def analyze_methods_phase: (TypeProf::Core::AST::Node nodes, TypeProf::Core::GlobalEnv genv) -> void
      def analyze_variables_phase: (TypeProf::Core::AST::Node nodes, TypeProf::Core::GlobalEnv genv) -> void
      def analyze_constants_phase: (TypeProf::Core::AST::Node nodes, TypeProf::Core::GlobalEnv genv) -> void
      def precompute_rename_entries: (TypeProf::Core::AST::Node nodes) -> Hash[location_key, String]
      def build_analysis_result: (Prism::ParseResult prism_result, ConcatenatedSource source, Hash[location_key, String] rename_map, Hash[location_key, Symbol] method_alias_map, Hash[location_key, String] method_transform_map, Hash[location_key, Hash[Symbol, String]] attr_rename_map, Hash[location_key, String] attr_ivar_entries, Hash[location_key, String] local_rename_entries) -> AnalysisResult
      def precompute_variable_names: (TypeProf::Core::AST::Node nodes, Hash[Integer, Hash[Symbol, String]] scope_mappings) -> Hash[location_key, String]
      def precompute_lambda_variable_names: (TypeProf::Core::AST::Node nodes, Hash[Integer, Hash[Symbol, String]] scope_mappings, Hash[location_key, String] variable_rename_entries) -> void
      def find_scope_var_name: (TypeProf::Core::CRef cref, Symbol var_name, Hash[Integer, Hash[Symbol, String]] scope_mappings) -> String?
      def walk_prism_tree: (Prism::Node? node) { (Prism::Node) -> void } -> void
      def block_has_non_required_params?: (Prism::ParametersNode? params) -> bool
      def collect_block_body_var_keys: (Prism::Node? body_node, Symbol var_name) -> Array[location_key]
      def augment_def_node_params: (TypeProf::Core::AST::Node nodes, Hash[Integer, Hash[Symbol, String]] scope_mappings, Symbol syntax_key) -> void
      def precompute_block_params: (TypeProf::Core::AST::Node nodes, Hash[Integer, Hash[Symbol, String]] scope_mappings, ?Hash[location_key, String] local_rename_entries) -> Hash[location_key, Hash[Symbol, String]]
      def augment_for_index: (TypeProf::Core::AST::Node nodes, Hash[Integer, Hash[Symbol, String]] scope_mappings, Symbol syntax_key) -> void
      def precompute_constant_resolution: (TypeProf::Core::AST::Node nodes) -> void
      def precompute_meta_nodes: (TypeProf::Core::AST::Node nodes) -> void
      def collect_syntax_data: (Prism::ProgramNode prism_ast) -> Hash[Array[Integer], Hash[Symbol, untyped]]
      def count_cpath_segments: (Prism::Node node) -> Integer
      def traverse_prism: (Prism::Node node, Hash[Array[Integer], Hash[Symbol, untyped]] data) -> void
    end
  end
end
