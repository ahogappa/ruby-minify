module RubyMinify
  class KeywordRenameMapping
    include UnionFind

    def initialize: () -> void
    def add_keyword_def: (untyped method_key, Symbol keyword_sym) -> void
    def add_keyword_call: (untyped method_key, Symbol keyword_sym, untyped symbol_node, untyped val_node) -> void
    def exclude_method: (untyped method_key) -> void
    def merge_groups: (untyped key1, untyped key2) -> void
    def each_method_key: () { (untyped) -> void } -> void
    def assign_short_names: () -> void
    def node_mapping: () -> Hash[untyped, String]
    def def_node_mapping: (Hash[untyped, Array[untyped]] def_node_registry) -> Hash[Integer, Hash[Symbol, String]]
    def build_variable_hints: () -> Hash[Integer, Hash[Symbol, String]]

    private

    def init_method: (untyped method_key) -> void
    def count_occurrences: (Array[untyped] keys, Symbol sym) -> Integer
  end
end
