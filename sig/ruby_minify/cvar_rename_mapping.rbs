module RubyMinify
  class CvarRenameMapping
    type cpath = Array[Symbol]
    type cvar_data = { read_nodes: Array[TypeProf::Core::AST::Node], write_nodes: Array[TypeProf::Core::AST::Node] }

    @class_cvars: Hash[cpath, Hash[Symbol, cvar_data]]
    @cpath_to_canonical: Hash[cpath, cpath]
    @excluded_cpaths: Set[cpath]
    @node_short_names: Hash[[Integer, Integer], String]

    def initialize: () -> void

    def add_read_site: (cpath cpath, Symbol cvar_name, TypeProf::Core::AST::Node node) -> void

    def add_write_site: (cpath cpath, Symbol cvar_name, TypeProf::Core::AST::Node node) -> void

    def exclude_cpath: (cpath cpath) -> void

    def each_canonical_cpath: () { (cpath) -> void } -> void

    def merge_with_ancestor: (cpath child_cpath, cpath ancestor_cpath) -> void

    def assign_short_names: () -> void

    def node_mapping: () -> Hash[[Integer, Integer], String]

    private

    def resolve_canonical: (cpath cpath) -> cpath

    def cvar_entry: (cpath cpath, Symbol cvar_name) -> cvar_data
  end
end
