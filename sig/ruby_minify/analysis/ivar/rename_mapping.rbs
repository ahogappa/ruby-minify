module RubyMinify
  class IvarRenameMapping
    type cpath = Array[Symbol]
    type ivar_data = { read_nodes: Array[TypeProf::Core::AST::Node], write_nodes: Array[TypeProf::Core::AST::Node] }

    @class_ivars: Hash[cpath, Hash[Symbol, ivar_data]]
    @cpath_to_canonical: Hash[cpath, cpath]
    @excluded_cpaths: Set[cpath]
    @node_short_names: Hash[[Integer, Integer], String]
    @reserved_names: Hash[cpath, Set[String]]

    def initialize: () -> void

    def add_read_site: (cpath cpath, Symbol ivar_name, TypeProf::Core::AST::Node node) -> void

    def add_write_site: (cpath cpath, Symbol ivar_name, TypeProf::Core::AST::Node node) -> void

    def exclude_cpath: (cpath cpath) -> void

    def reserve_name: (cpath cpath, String short_name) -> void

    def each_canonical_cpath: () { (cpath) -> void } -> void

    def merge_with_ancestor: (cpath child_cpath, cpath ancestor_cpath) -> void

    def assign_short_names: () -> void

    def node_mapping: () -> Hash[[Integer, Integer], String]

    private

    def resolve_canonical: (cpath cpath) -> cpath

    def ivar_entry: (cpath cpath, Symbol ivar_name) -> ivar_data
  end
end
