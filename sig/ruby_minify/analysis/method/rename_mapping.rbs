module RubyMinify
  EXCLUDED_METHODS: Set[Symbol]

  type method_key = [Array[Symbol], bool, Symbol]

  class MethodRenameMapping
    include UnionFind

    class MethodGroupEntry
      attr_accessor keys: Array[method_key]
      attr_accessor original_name: String
      attr_accessor total_occurrences: Integer

      def initialize: (?Array[method_key]?, ?String?, ?Integer?) -> void
    end

    @methods: Hash[method_key, { def_nodes: Array[untyped], call_sites: Array[untyped] }]
    @node_to_key: Hash[Integer, method_key]
    @node_short_names: Hash[untyped, String]
    @key_short_names: Hash[method_key, String]
    @implicit_receiver_sites: Hash[Integer, Integer]
    @frozen: bool

    def initialize: () -> void

    def add_method: (method_key method_key, untyped? def_node) -> void

    def has_method?: (method_key method_key) -> bool

    def add_call_site: (untyped call_node, method_key method_key, has_receiver: bool) -> void

    def exclude_methods_by_mid: (untyped mids) -> void

    def merge_all_by_mid: (Symbol mid) -> void

    def add_unresolved_sites_for_mid: (Symbol mid, Array[untyped] call_nodes) -> void

    def assign_short_names: (untyped scope_mappings, ?untyped? genv) -> void

    def short_name_for: (untyped node_location_key) -> String?

    def short_name_for_key: (method_key method_key) -> String?

    def node_mapping: () -> Hash[untyped, String]

    def each_method_key: () { (method_key) -> void } -> void

    def method_mids: () -> Set[Symbol]

    def each_cpath_for_mid: (Symbol mid) { (Array[Symbol], bool) -> void } -> void

    private

    def build_group_entries: (Hash[untyped, Array[method_key]] groups) -> Array[MethodGroupEntry]

    def build_scope_vars: (untyped scope_mappings) -> Hash[Integer, Set[String]]

    def build_existing_method_names: (untyped genv) -> [Hash[untyped, Set[String]], Hash[Symbol, untyped]]

    def find_shortest_name: (Array[method_key] keys, Hash[Integer, Set[String]] scope_vars, Hash[untyped, Set[String]] existing_methods) -> String

    def propagate_short_name: (Array[method_key] keys, String short_name, Hash[untyped, Set[String]] existing_methods, Hash[Symbol, untyped] hierarchy) -> void

    def assign_short_name: (Array[method_key] keys, String short_name) -> void
  end
end
